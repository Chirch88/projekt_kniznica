<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" styleClass="root-pane" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Kniznica02.Controller">
    <top>
        <Label id="titleLabel" alignment="CENTER" prefHeight="53.0" prefWidth="287.0" text="Knižnica Systém" BorderPane.alignment="CENTER" />
    </top>
    <bottom>
        <HBox id="bottomBar" alignment="CENTER" prefHeight="60.0" prefWidth="600.0" BorderPane.alignment="CENTER">
            <children>
                <Button mnemonicParsing="false" onAction="#pridatAction" text="Pridať">
                    <HBox.margin>
                        <Insets left="5.0" right="5.0" />
                    </HBox.margin>
                </Button>
                <Button mnemonicParsing="false" onAction="#vyraditAction" text="Vyradiť">
                    <HBox.margin>
                        <Insets left="5.0" right="5.0" />
                    </HBox.margin>
                </Button>
                <Separator orientation="VERTICAL" />
                <Button mnemonicParsing="false" onAction="#pozicatAction" text="Požičať">
                    <HBox.margin>
                        <Insets left="5.0" right="5.0" />
                    </HBox.margin>
                </Button>
                <Button mnemonicParsing="false" onAction="#vratitAction" text="Vrátiť">
                    <HBox.margin>
                        <Insets left="5.0" right="5.0" />
                    </HBox.margin>
                </Button>
                <Separator orientation="VERTICAL" />
                <Button mnemonicParsing="false" onAction="#filtrovatAction" text="Filtrovať">
                    <HBox.margin>
                        <Insets left="5.0" right="5.0" />
                    </HBox.margin>
                </Button>
                <Button mnemonicParsing="false" onAction="#zavrietAction" text="Koniec">
                    <HBox.margin>
                        <Insets left="5.0" right="5.0" />
                    </HBox.margin>
                </Button>
            </children>
        </HBox>
    </bottom>
    <center>
        <TableView fx:id="kniznicaTable" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
            </BorderPane.margin>
            <columns>
                <TableColumn fx:id="colNazov" prefWidth="75.0" text="Názov" />
                <TableColumn fx:id="colAutor" prefWidth="75.0" text="Autor" />
                <TableColumn fx:id="colKategoria" prefWidth="75.0" text="Kategória" />
                <TableColumn fx:id="colStav" prefWidth="75.0" text="Stav" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </center>
</BorderPane>
